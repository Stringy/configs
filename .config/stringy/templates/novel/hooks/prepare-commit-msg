#!/usr/bin/sh
#
# Append word count stats to commit messages

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only add stats for regular commits, not merges/amends
case "$COMMIT_SOURCE" in
    merge|squash|commit) exit 0 ;;
esac

total=0
for f in chapters/*.md; do
    [ -f "$f" ] || continue
    words=$(wc -w < "$f")
    total=$((total + words))
done

# Calculate delta from last commit
prev=0
for f in $(git ls-tree --name-only HEAD chapters/ 2>/dev/null); do
    words=$(git show "HEAD:$f" 2>/dev/null | wc -w)
    prev=$((prev + words))
done
delta=$((total - prev))

if [ $delta -ge 0 ]; then
    delta_str="+${delta}"
else
    delta_str="${delta}"
fi

printf "\n[wordcount: %s total, %s this commit]\n" "$total" "$delta_str" >> "$COMMIT_MSG_FILE"
