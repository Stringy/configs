{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "instructions": [
    "/home/ghutton/.claude/CLAUDE.md",
    "/home/ghutton/.claude/RTK.md"
  ],
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices, security, and maintainability",
      "model": "anthropic/claude-opus-4-6",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "careful": {
      "description": "Extra cautious mode for production changes - asks before modifications",
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "write": "ask"
      }
    }
  },
  "command": {
    "rtk": {
      "description": "Token optimization wrapper",
      "template": "Use rtk wrapper for token-optimized output: rtk $ARGUMENTS"
    },
    "gain": {
      "description": "Show token savings analytics",
      "template": "Run rtk gain to show token savings"
    },
    "postgres-dev": {
      "description": "Run PostgreSQL integration tests",
      "template": "Run postgres-dev for sql_integration tests"
    },
    "review": {
      "description": "Review code changes",
      "agent": "code-reviewer",
      "template": "Review the current changes for code quality, security issues, and best practices"
    }
  },
  "mcp": {
    "atlassian-sooperset": {
      "type": "local",
      "command": [
        "podman", "run", "-i", "--rm",
        "-e", "JIRA_URL",
        "-e", "JIRA_USERNAME",
        "-e", "JIRA_API_TOKEN",
        "-e", "CONFLUENCE_URL",
        "-e", "CONFLUENCE_USERNAME",
        "-e", "CONFLUENCE_API_TOKEN",
        "-e", "READ_ONLY_MODE",
        "-e", "MCP_DISABLE_WAIT",
        "-e", "TOOLSETS",
        "ghcr.io/sooperset/mcp-atlassian:0.21.1"
      ],
      "environment": {
        "JIRA_URL": "https://redhat.atlassian.net",
        "JIRA_USERNAME": "ghutton@redhat.com",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}",
        "CONFLUENCE_URL": "https://redhat.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "ghutton@redhat.com",
        "CONFLUENCE_API_TOKEN": "{env:JIRA_API_TOKEN}",
        "READ_ONLY_MODE": "false",
        "MCP_DISABLE_WAIT": "true",
        "TOOLSETS": "all"
      },
      "enabled": true
    }
  },
  "lsp": {
    "fish-lsp": {
      "command": ["fish-lsp", "start"],
      "extensions": [".fish"]
    }
  },
  "plugin": [
    "opencode-claude-auth@latest"
  ]
}
